@implements IDisposable
@inject AuthState AuthState
@inject ThemeState ThemeState
@inject CartState CartState
@inject CartApiService CartApi
@inject AuthApiService AuthApi
@inject NavigationManager Navigation

<header class="nami-navbar">
    <div class="nami-navbar-inner">
        <a class="nami-logo" href="/">Ñami<span class="nami-logo-dot">.</span></a>

        @if (AuthState.Role == "Client")
        {
            <nav style="display:flex; gap:6px; margin-left:8px;">
                <a class="nami-chip @(IsActive("/") ? "nami-chip-active" : "")" href="/">Inicio</a>
                <a class="nami-chip @(IsActive("/mis-pedidos") ? "nami-chip-active" : "")" href="/mis-pedidos">Mis pedidos</a>
            </nav>
        }
        else if (AuthState.Role == "Delivery")
        {
            <nav style="display:flex; gap:6px; margin-left:8px;">
                <a class="nami-chip @(IsActive("/repartidor") ? "nami-chip-active" : "")" href="/repartidor">Mis entregas</a>
            </nav>
        }
        else if (AuthState.Role == "Administrator")
        {
            <nav style="display:flex; gap:6px; margin-left:8px;">
                <a class="nami-chip @(IsActive("/admin") ? "nami-chip-active" : "")" href="/admin">Panel admin</a>
            </nav>
        }

        <div style="flex:1;"></div>

        @if (AuthState.IsAuthenticated)
        {
            <a class="nami-icon-btn" style="width:auto; padding:8px 14px; border-radius:999px; font-size:13px; font-weight:600; color:var(--nami-muted);" href="/notificaciones">🔔</a>
        }

        <button class="nami-btn nami-btn-ghost nami-btn-sm" @onclick="ToggleTheme" title="Cambiar tema">
            <span style="width:8px; height:8px; border-radius:50%; background:var(--nami-accent); display:inline-block;"></span>
            @(ThemeState.Current == "dark" ? "Oscuro" : "Claro")
        </button>

        @if (AuthState.Role == "Client")
        {
            <button class="nami-btn nami-btn-ghost" style="position:relative;" @onclick="GoCart">
                Carrito
                @if (CartState.ItemCount > 0)
                {
                    <span class="nami-cart-badge nami-cart-bump" @key="CartState.BumpToken">@CartState.ItemCount</span>
                }
            </button>
        }

        @if (!AuthState.IsAuthenticated)
        {
            <a class="nami-btn nami-btn-primary" href="/login">Ingresar</a>
        }
        else
        {
            <div style="display:flex; align-items:center; gap:10px;">
                <div class="nami-avatar">@Initials()</div>
                <button class="nami-btn nami-btn-ghost nami-btn-sm" @onclick="LogoutAsync">Salir</button>
            </div>
        }
    </div>
</header>

@code {
    protected override async Task OnInitializedAsync()
    {
        AuthState.OnChange += HandleAuthChange;
        ThemeState.OnChange += StateHasChanged;
        CartState.OnChange += StateHasChanged;

        if (AuthState.Role == "Client")
            await RefreshCartCountAsync();
    }

    private async void HandleAuthChange()
    {
        if (AuthState.Role == "Client")
            await RefreshCartCountAsync();
        else
            CartState.SetCount(0);

        await InvokeAsync(StateHasChanged);
    }

    private async Task RefreshCartCountAsync()
    {
        try
        {
            var cart = await CartApi.GetCart();
            CartState.SetCount(cart?.Items.Sum(i => i.Quantity) ?? 0);
        }
        catch
        {
            // El navbar no debe romperse si la API aún no respondió; se reintentará en la próxima carga.
        }
    }

    private bool IsActive(string path)
    {
        var relative = "/" + Navigation.ToBaseRelativePath(Navigation.Uri);
        return relative == path || (path != "/" && relative.StartsWith(path));
    }

    private string Initials()
    {
        var user = AuthState.CurrentUser;
        if (user is null) return "?";
        var f = user.FirstName.Length > 0 ? user.FirstName[0] : '?';
        var l = user.LastName.Length > 0 ? user.LastName[0] : ' ';
        return $"{f}{l}".ToUpperInvariant();
    }

    private void ToggleTheme() => ThemeState.Toggle();

    private void GoCart() => Navigation.NavigateTo("/carrito");

    private async Task LogoutAsync()
    {
        try
        {
            await AuthApi.Logout();
        }
        catch
        {
            // El JWT es stateless: si la llamada falla (red, token ya vencido, etc.)
            // igual se cierra la sesión localmente.
        }

        AuthState.Clear();
        Navigation.NavigateTo("/", forceLoad: false);
    }

    public void Dispose()
    {
        AuthState.OnChange -= HandleAuthChange;
        ThemeState.OnChange -= StateHasChanged;
        CartState.OnChange -= StateHasChanged;
    }
}
