@page "/repartidor"
@inject OrderApiService OrderApi
@inject UserApiService UserApi
@inject AuthState AuthState
@inject NavigationManager Navigation

<PageTitle>Mis entregas</PageTitle>

@if (!AuthState.IsAuthenticated || AuthState.Role != "Delivery")
{
    <p>Esta sección es solo para repartidores.</p>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>Mis entregas asignadas</h3>
        <div class="form-check form-switch">
            <input class="form-check-input" type="checkbox" role="switch" checked="@_available" @onchange="ToggleAvailabilityAsync" />
            <label class="form-check-label">Disponible</label>
        </div>
    </div>

    @if (_orders is null)
    {
        <p>Cargando...</p>
    }
    else if (_orders.Count == 0)
    {
        <p class="text-muted">No tienes entregas asignadas por el momento.</p>
    }
    else
    {
        <table class="table">
            <thead><tr><th>#</th><th>Restaurante</th><th>Dirección</th><th>Estado</th><th></th></tr></thead>
            <tbody>
                @foreach (var order in _orders)
                {
                    <tr>
                        <td>@order.Id</td>
                        <td>@order.RestaurantName</td>
                        <td>@order.Address</td>
                        <td><span class="badge bg-info text-dark">@order.Status</span></td>
                        <td><a class="btn btn-sm btn-outline-primary" href="/pedido/@order.Id">Gestionar</a></td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    private List<OrderDto>? _orders;
    private bool _available = true;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthState.IsAuthenticated || AuthState.Role != "Delivery")
        {
            Navigation.NavigateTo("/login");
            return;
        }

        _orders = await OrderApi.GetMyDeliveries();
    }

    private async Task ToggleAvailabilityAsync(ChangeEventArgs e)
    {
        _available = e.Value is bool b && b;
        await UserApi.UpdateMyAvailability(new UpdateDeliveryAvailabilityRequest(_available));
    }
}
