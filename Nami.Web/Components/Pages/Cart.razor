@page "/carrito"
@inject CartApiService CartApi
@inject OrderApiService OrderApi
@inject AuthState AuthState
@inject NavigationManager Navigation

<PageTitle>Carrito</PageTitle>

<h3 class="mb-3">Mi carrito</h3>

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger">@_error</div>
}

@if (_cart is null)
{
    <p>Cargando...</p>
}
else if (_cart.Items.Count == 0)
{
    <p class="text-muted">Tu carrito está vacío. <a href="/">Explora restaurantes</a>.</p>
}
else
{
    <table class="table align-middle">
        <thead>
            <tr>
                <th>Producto</th>
                <th>Precio</th>
                <th>Cantidad</th>
                <th>Subtotal</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in _cart.Items)
            {
                <tr>
                    <td>@item.ProductName</td>
                    <td>@item.UnitPrice.ToString("C")</td>
                    <td style="max-width:100px">
                        <input type="number" min="1" class="form-control form-control-sm" value="@item.Quantity"
                               @onchange="e => UpdateQuantityAsync(item.Id, e.Value)" />
                    </td>
                    <td>@item.Subtotal.ToString("C")</td>
                    <td>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveItemAsync(item.Id)">Quitar</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="d-flex justify-content-end">
        <h5>Subtotal: @_cart.Subtotal.ToString("C")</h5>
    </div>

    <hr />

    <h5>Confirmar pedido</h5>
    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label">Dirección de entrega</label>
            <input class="form-control" @bind="_address" />
        </div>
        <div class="col-md-3 mb-3">
            <label class="form-label">Método de pago</label>
            <select class="form-select" @bind="_paymentMethod">
                <option value="@PaymentMethod.Cash">Efectivo</option>
                <option value="@PaymentMethod.Card">Tarjeta</option>
                <option value="@PaymentMethod.Transfer">Transferencia</option>
            </select>
        </div>
        <div class="col-md-3 mb-3">
            <label class="form-label">Código de promoción (opcional)</label>
            <input class="form-control" @bind="_promoCode" />
        </div>
    </div>
    <button class="btn btn-success" disabled="@_placing" @onclick="PlaceOrderAsync">
        @(_placing ? "Procesando..." : "Confirmar pedido")
    </button>
}

@code {
    private CartDto? _cart;
    private string _address = string.Empty;
    private PaymentMethod _paymentMethod = PaymentMethod.Cash;
    private string _promoCode = string.Empty;
    private string? _error;
    private bool _placing;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthState.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        _address = AuthState.CurrentUser?.Address ?? string.Empty;
        await LoadCartAsync();
    }

    private async Task LoadCartAsync() => _cart = await CartApi.GetCart();

    private async Task UpdateQuantityAsync(int itemId, object? value)
    {
        if (value is null || !int.TryParse(value.ToString(), out var quantity) || quantity <= 0) return;

        try
        {
            _cart = await CartApi.UpdateItem(itemId, new UpdateCartItemRequest(quantity));
        }
        catch (ApiException ex)
        {
            _error = ex.Message;
        }
    }

    private async Task RemoveItemAsync(int itemId)
    {
        try
        {
            _cart = await CartApi.RemoveItem(itemId);
        }
        catch (ApiException ex)
        {
            _error = ex.Message;
        }
    }

    private async Task PlaceOrderAsync()
    {
        if (string.IsNullOrWhiteSpace(_address))
        {
            _error = "Ingresa una dirección de entrega.";
            return;
        }

        _placing = true;
        _error = null;
        try
        {
            var request = new CreateOrderRequest(_address, _paymentMethod,
                string.IsNullOrWhiteSpace(_promoCode) ? null : _promoCode);

            var order = await OrderApi.Create(request);
            if (order is not null)
                Navigation.NavigateTo($"/pedido/{order.Id}");
        }
        catch (ApiException ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _placing = false;
        }
    }
}
