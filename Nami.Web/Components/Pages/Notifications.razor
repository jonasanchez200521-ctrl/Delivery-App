@page "/notificaciones"
@inject NotificationApiService NotificationApi
@inject AuthState AuthState
@inject NavigationManager Navigation

<PageTitle>Notificaciones</PageTitle>

<h3 class="mb-3">Notificaciones</h3>

@if (_notifications is null)
{
    <p>Cargando...</p>
}
else if (_notifications.Count == 0)
{
    <p class="text-muted">No tienes notificaciones.</p>
}
else
{
    <div class="list-group">
        @foreach (var notification in _notifications)
        {
            <div class="list-group-item @(notification.IsRead ? "" : "list-group-item-warning")">
                <div class="d-flex justify-content-between">
                    <span>@notification.Message</span>
                    <small class="text-muted">@notification.Date.ToLocalTime().ToString("g")</small>
                </div>
                @if (!notification.IsRead)
                {
                    <button class="btn btn-sm btn-link p-0" @onclick="() => MarkAsReadAsync(notification.Id)">Marcar como leída</button>
                }
            </div>
        }
    </div>
}

@code {
    private List<NotificationDto>? _notifications;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthState.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync() => _notifications = await NotificationApi.GetMine();

    private async Task MarkAsReadAsync(int id)
    {
        await NotificationApi.MarkAsRead(id);
        await LoadAsync();
    }
}
