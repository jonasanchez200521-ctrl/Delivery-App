@page "/admin/promociones"
@inject PromotionApiService PromotionApi
@inject AuthState AuthState
@inject NavigationManager Navigation

<PageTitle>Promociones — Admin</PageTitle>

<AdminNav />

@if (!AuthState.IsAuthenticated || AuthState.Role != "Administrator")
{
    <p>Esta sección es solo para administradores.</p>
}
else
{
    <h3 class="nami-heading" style="margin:0 0 18px; font-size:22px;">Promociones</h3>

    @if (!string.IsNullOrEmpty(_message))
    {
        <div class="alert alert-info">@_message</div>
    }

    <div class="nami-panel" style="padding:20px; margin-bottom:22px;">
        <div class="row g-2">
            <div class="col-md-2"><input class="nami-input" placeholder="Código" @bind="_code" /></div>
            <div class="col-md-2"><input type="number" class="nami-input" placeholder="% Descuento" @bind="_discount" /></div>
            <div class="col-md-3"><input type="date" class="nami-input" @bind="_startDate" /></div>
            <div class="col-md-3"><input type="date" class="nami-input" @bind="_endDate" /></div>
            <div class="col-md-2"><button class="nami-btn nami-btn-primary nami-btn-block" style="height:100%;" @onclick="CreateAsync">Crear</button></div>
        </div>
    </div>

    @if (_promotions is null)
    {
        <div class="nami-skel" style="height:150px;"></div>
    }
    else
    {
        <div class="nami-panel" style="padding:20px; overflow-x:auto;">
            <table class="nami-table">
                <thead><tr><th>Código</th><th>Descuento</th><th>Vigencia</th><th>Activa</th><th></th></tr></thead>
                <tbody>
                    @foreach (var promo in _promotions)
                    {
                        <tr>
                            <td style="font-weight:700;">@promo.Code</td>
                            <td>@promo.Discount %</td>
                            <td style="color:var(--nami-muted);">@promo.StartDate.ToShortDateString() - @promo.EndDate.ToShortDateString()</td>
                            <td>
                                <span class="nami-badge" style="background:@(promo.IsActive ? "rgba(74,222,128,.18)" : "var(--nami-ph2)"); color:@(promo.IsActive ? "var(--nami-success)" : "var(--nami-muted)");">@(promo.IsActive ? "Sí" : "No")</span>
                            </td>
                            <td style="text-align:right;"><button class="nami-btn nami-btn-sm" style="color:var(--nami-danger);" @onclick="() => DeleteAsync(promo.Id)">Eliminar</button></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@code {
    private List<PromotionDto>? _promotions;
    private string _code = string.Empty;
    private decimal _discount;
    private DateTime _startDate = DateTime.Today;
    private DateTime _endDate = DateTime.Today.AddMonths(1);
    private string? _message;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthState.IsAuthenticated || AuthState.Role != "Administrator")
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync() => _promotions = await PromotionApi.GetAll();

    private async Task CreateAsync()
    {
        if (string.IsNullOrWhiteSpace(_code)) return;

        try
        {
            await PromotionApi.Create(new CreatePromotionRequest(_code, _discount, _startDate, _endDate));
            _code = string.Empty;
            _discount = 0;
            await LoadAsync();
        }
        catch (ApiException ex)
        {
            _message = ex.Message;
        }
    }

    private async Task DeleteAsync(int id)
    {
        try
        {
            await PromotionApi.Delete(id);
            await LoadAsync();
        }
        catch (ApiException ex)
        {
            _message = ex.Message;
        }
    }
}
