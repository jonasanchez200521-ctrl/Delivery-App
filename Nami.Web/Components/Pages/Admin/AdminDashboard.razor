@page "/admin"
@inject ReportApiService ReportApi
@inject AuthState AuthState
@inject NavigationManager Navigation

<PageTitle>Panel admin</PageTitle>

<AdminNav />

@if (!AuthState.IsAuthenticated || AuthState.Role != "Administrator")
{
    <p>Esta sección es solo para administradores.</p>
}
else if (_report is null)
{
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(210px,1fr)); gap:16px;">
        @for (var i = 0; i < 4; i++)
        {
            <div class="nami-skel" style="height:96px;"></div>
        }
    </div>
}
else
{
    <h2 class="nami-heading" style="margin:0 0 20px; font-size:26px;">Dashboard</h2>

    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(210px,1fr)); gap:16px; margin-bottom:24px;">
        <div class="nami-card" style="padding:20px 22px;">
            <div style="color:var(--nami-muted); font-size:13px; font-weight:600; margin-bottom:12px;">Pedidos totales</div>
            <div class="nami-heading" style="font-size:26px;">@_report.TotalOrders</div>
        </div>
        <div class="nami-card" style="padding:20px 22px;">
            <div style="color:var(--nami-muted); font-size:13px; font-weight:600; margin-bottom:12px;">Ventas totales</div>
            <div class="nami-heading" style="font-size:26px; color:var(--nami-accent);">@_report.TotalSales.ToString("C")</div>
        </div>
        <div class="nami-card" style="padding:20px 22px;">
            <div style="color:var(--nami-muted); font-size:13px; font-weight:600; margin-bottom:12px;">Pagos procesados</div>
            <div class="nami-heading" style="font-size:26px;">@_report.TotalPayments</div>
        </div>
        <div class="nami-card" style="padding:20px 22px;">
            <div style="color:var(--nami-muted); font-size:13px; font-weight:600; margin-bottom:12px;">Ingresos cobrados</div>
            <div class="nami-heading" style="font-size:26px; color:var(--nami-accent);">@_report.TotalRevenueCollected.ToString("C")</div>
        </div>
    </div>

    <div class="nami-grid-2" style="margin-bottom:24px;">
        <div class="nami-panel" style="padding:24px;">
            <h3 class="nami-heading" style="margin:0 0 18px; font-size:17px;">Pedidos por estado</h3>
            <div style="display:flex; flex-direction:column; gap:12px;">
                @foreach (var kv in _report.OrdersByStatus)
                {
                    <div>
                        <div style="display:flex; justify-content:space-between; font-size:13.5px; margin-bottom:5px;">
                            <span style="color:var(--nami-muted); font-weight:600;">@kv.Key</span>
                            <span style="font-weight:700;">@kv.Value</span>
                        </div>
                        <div style="height:8px; border-radius:999px; background:var(--nami-ph2); overflow:hidden;">
                            <div style="height:100%; border-radius:999px; background:var(--nami-accent); width:@(BarWidth(kv.Value, MaxOrdersByStatus))%;"></div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="nami-panel" style="padding:24px;">
            <h3 class="nami-heading" style="margin:0 0 18px; font-size:17px;">Usuarios por tipo</h3>
            <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(120px,1fr)); gap:12px;">
                @foreach (var kv in _report.UsersByType)
                {
                    <div class="nami-card" style="padding:16px 18px;">
                        <div style="color:var(--nami-muted); font-size:12.5px; font-weight:600; margin-bottom:8px;">@kv.Key</div>
                        <div class="nami-heading" style="font-size:24px;">@kv.Value</div>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    private ReportDto? _report;

    private int MaxOrdersByStatus => _report?.OrdersByStatus.Values.DefaultIfEmpty(1).Max() ?? 1;

    private double BarWidth(int value, int max) => max == 0 ? 0 : Math.Round(value * 100.0 / max, 1);

    protected override async Task OnInitializedAsync()
    {
        if (!AuthState.IsAuthenticated || AuthState.Role != "Administrator")
        {
            Navigation.NavigateTo("/login");
            return;
        }

        _report = await ReportApi.GetReport();
    }
}
