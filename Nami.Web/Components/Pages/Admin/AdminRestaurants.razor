@page "/admin/restaurantes"
@inject CatalogApiService CatalogApi
@inject AuthState AuthState
@inject NavigationManager Navigation

<PageTitle>Restaurantes — Admin</PageTitle>

<AdminNav />

@if (!AuthState.IsAuthenticated || AuthState.Role != "Administrator")
{
    <p>Esta sección es solo para administradores.</p>
}
else
{
    <h3 class="nami-heading" style="margin:0 0 18px; font-size:22px;">Restaurantes</h3>

    @if (!string.IsNullOrEmpty(_message))
    {
        <div class="alert alert-info">@_message</div>
    }

    <div class="nami-panel" style="padding:20px; margin-bottom:22px;">
        <h5 class="nami-heading" style="margin:0 0 4px; font-size:15px;">@(_editingId is null ? "Nuevo restaurante" : $"Editando restaurante #{_editingId}")</h5>
        <p style="margin:0 0 12px; color:var(--nami-muted); font-size:12.5px;">
            Pega las coordenadas de Google Maps (clic derecho sobre el punto → copiar lo primero que aparece: latitud, longitud).
        </p>
        <div class="row g-2">
            <div class="col-md-4"><input class="nami-input" placeholder="Nombre" @bind="_form.Name" /></div>
            <div class="col-md-4"><input class="nami-input" placeholder="Dirección" @bind="_form.Address" /></div>
            <div class="col-md-4"><input class="nami-input" placeholder="Categoría" @bind="_form.Category" /></div>
            <div class="col-md-6"><input class="nami-input" placeholder="URL de imagen (https://...)" @bind="_form.ImageUrl" /></div>
            <div class="col-md-3"><input type="number" step="0.000001" class="nami-input" placeholder="Latitud (ej. -0.1807)" @bind="_form.Latitude" /></div>
            <div class="col-md-3"><input type="number" step="0.000001" class="nami-input" placeholder="Longitud (ej. -78.4678)" @bind="_form.Longitude" /></div>
            @if (_editingId is not null)
            {
                <div class="col-md-3">
                    <select class="nami-select" @bind="_form.Status">
                        <option value="@RestaurantStatus.Active">Activo</option>
                        <option value="@RestaurantStatus.Inactive">Inactivo</option>
                    </select>
                </div>
                <div class="col-md-3"><input type="number" step="0.1" min="0" max="5" class="nami-input" placeholder="Rating" @bind="_form.Rating" /></div>
            }
        </div>
        <div style="display:flex; gap:8px; margin-top:12px;">
            @if (_editingId is null)
            {
                <button class="nami-btn nami-btn-primary" @onclick="CreateAsync">Crear</button>
            }
            else
            {
                <button class="nami-btn nami-btn-primary" @onclick="SaveEditAsync">Guardar cambios</button>
                <button class="nami-btn nami-btn-ghost" @onclick="CancelEdit">Cancelar</button>
            }
        </div>
    </div>

    @if (_restaurants is null)
    {
        <div class="nami-skel" style="height:200px;"></div>
    }
    else
    {
        <div class="nami-panel" style="padding:20px; overflow-x:auto;">
            <table class="nami-table" style="min-width:760px;">
                <thead><tr><th>Imagen</th><th>Nombre</th><th>Dirección</th><th>Categoría</th><th>Estado</th><th>Rating</th><th style="text-align:right;">Acciones</th></tr></thead>
                <tbody>
                    @foreach (var restaurant in _restaurants)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(restaurant.ImageUrl))
                                {
                                    <div style="width:40px; height:40px; border-radius:8px; background-size:cover; background-position:center; background-image:url('@restaurant.ImageUrl');"></div>
                                }
                                else
                                {
                                    <div style="width:40px; height:40px; border-radius:8px; background:var(--nami-ph2);"></div>
                                }
                            </td>
                            <td style="font-weight:700;">@restaurant.Name</td>
                            <td style="color:var(--nami-muted);">@restaurant.Address</td>
                            <td>@restaurant.Category</td>
                            <td>
                                <span class="nami-badge" style="background:@(restaurant.Status == RestaurantStatus.Active ? "rgba(74,222,128,.18)" : "var(--nami-ph2)"); color:@(restaurant.Status == RestaurantStatus.Active ? "var(--nami-success)" : "var(--nami-muted)");">@restaurant.Status</span>
                            </td>
                            <td>★ @restaurant.Rating.ToString("0.0")</td>
                            <td style="text-align:right; white-space:nowrap;">
                                <button class="nami-btn nami-btn-ghost nami-btn-sm" @onclick="() => StartEdit(restaurant)">Editar</button>
                                <button class="nami-btn nami-btn-ghost nami-btn-sm" @onclick="() => ToggleStatusAsync(restaurant)">
                                    @(restaurant.Status == RestaurantStatus.Active ? "Desactivar" : "Activar")
                                </button>
                                <button class="nami-btn nami-btn-sm" style="color:var(--nami-danger);" @onclick="() => DeleteAsync(restaurant.Id)">Eliminar</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@code {
    private List<RestaurantDto>? _restaurants;
    private int? _editingId;
    private readonly RestaurantFormModel _form = new();
    private string? _message;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthState.IsAuthenticated || AuthState.Role != "Administrator")
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync() => _restaurants = await CatalogApi.GetRestaurants();

    private async Task CreateAsync()
    {
        if (string.IsNullOrWhiteSpace(_form.Name)) return;

        try
        {
            await CatalogApi.CreateRestaurant(new CreateRestaurantRequest(
                _form.Name, _form.Address, _form.Category,
                string.IsNullOrWhiteSpace(_form.ImageUrl) ? null : _form.ImageUrl,
                _form.Latitude, _form.Longitude));

            _form.Reset();
            await LoadAsync();
        }
        catch (ApiException ex)
        {
            _message = ex.Message;
        }
    }

    private void StartEdit(RestaurantDto restaurant)
    {
        _editingId = restaurant.Id;
        _form.Name = restaurant.Name;
        _form.Address = restaurant.Address;
        _form.Category = restaurant.Category;
        _form.ImageUrl = restaurant.ImageUrl ?? string.Empty;
        _form.Latitude = restaurant.Latitude;
        _form.Longitude = restaurant.Longitude;
        _form.Status = restaurant.Status;
        _form.Rating = restaurant.Rating;
        _message = null;
    }

    private void CancelEdit()
    {
        _editingId = null;
        _form.Reset();
    }

    private async Task SaveEditAsync()
    {
        if (_editingId is null) return;

        if (string.IsNullOrWhiteSpace(_form.Name)) return;

        try
        {
            await CatalogApi.UpdateRestaurant(_editingId.Value, new UpdateRestaurantRequest(
                _form.Name, _form.Address, _form.Category, _form.Status, _form.Rating,
                string.IsNullOrWhiteSpace(_form.ImageUrl) ? null : _form.ImageUrl,
                _form.Latitude, _form.Longitude));

            _editingId = null;
            _form.Reset();
            await LoadAsync();
        }
        catch (ApiException ex)
        {
            _message = ex.Message;
        }
    }

    private async Task ToggleStatusAsync(RestaurantDto restaurant)
    {
        var newStatus = restaurant.Status == RestaurantStatus.Active ? RestaurantStatus.Inactive : RestaurantStatus.Active;
        await CatalogApi.UpdateRestaurant(restaurant.Id,
            new UpdateRestaurantRequest(restaurant.Name, restaurant.Address, restaurant.Category, newStatus, restaurant.Rating,
                restaurant.ImageUrl, restaurant.Latitude, restaurant.Longitude));
        await LoadAsync();
    }

    private async Task DeleteAsync(int id)
    {
        try
        {
            await CatalogApi.DeleteRestaurant(id);
            if (_editingId == id) CancelEdit();
            await LoadAsync();
        }
        catch (ApiException ex)
        {
            _message = ex.Message;
        }
    }

    private class RestaurantFormModel
    {
        // Centro de Quito por defecto: punto de partida razonable si el admin no pega coordenadas propias.
        private const double DefaultQuitoLatitude = -0.1807;
        private const double DefaultQuitoLongitude = -78.4678;

        public string Name { get; set; } = string.Empty;
        public string Address { get; set; } = string.Empty;
        public string Category { get; set; } = string.Empty;
        public string ImageUrl { get; set; } = string.Empty;
        public double Latitude { get; set; } = DefaultQuitoLatitude;
        public double Longitude { get; set; } = DefaultQuitoLongitude;
        public RestaurantStatus Status { get; set; } = RestaurantStatus.Active;
        public double Rating { get; set; }

        public void Reset()
        {
            Name = string.Empty;
            Address = string.Empty;
            Category = string.Empty;
            ImageUrl = string.Empty;
            Latitude = DefaultQuitoLatitude;
            Longitude = DefaultQuitoLongitude;
            Status = RestaurantStatus.Active;
            Rating = 0;
        }
    }
}
