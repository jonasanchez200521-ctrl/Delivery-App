@page "/pedido/{OrderId:int}"
@inject OrderApiService OrderApi
@inject UserApiService UserApi
@inject AuthState AuthState
@inject NavigationManager Navigation

<PageTitle>Pedido #@OrderId</PageTitle>

@if (!AuthState.IsAuthenticated)
{
    <p>Debes <a href="/login">ingresar</a> para ver este pedido.</p>
}
else if (_order is null)
{
    <p>Cargando...</p>
}
else
{
    <h3>Pedido #@_order.Id</h3>

    @if (!string.IsNullOrEmpty(_message))
    {
        <div class="alert alert-info">@_message</div>
    }

    <dl class="row">
        <dt class="col-sm-3">Restaurante</dt>
        <dd class="col-sm-9">@_order.RestaurantName</dd>
        <dt class="col-sm-3">Cliente</dt>
        <dd class="col-sm-9">@_order.ClientName</dd>
        <dt class="col-sm-3">Repartidor</dt>
        <dd class="col-sm-9">@(_order.DeliveryName ?? "Sin asignar")</dd>
        <dt class="col-sm-3">Dirección</dt>
        <dd class="col-sm-9">@_order.Address</dd>
        <dt class="col-sm-3">Estado</dt>
        <dd class="col-sm-9"><span class="badge bg-info text-dark">@_order.Status</span></dd>
        <dt class="col-sm-3">Fecha del pedido</dt>
        <dd class="col-sm-9">@_order.OrderDate.ToLocalTime().ToString("g")</dd>
        <dt class="col-sm-3">Fecha de entrega</dt>
        <dd class="col-sm-9">@(_order.DeliveryDate?.ToLocalTime().ToString("g") ?? "-")</dd>
    </dl>

    <table class="table">
        <thead><tr><th>Producto</th><th>Cantidad</th><th>Precio</th><th>Subtotal</th></tr></thead>
        <tbody>
            @foreach (var detail in _order.Details)
            {
                <tr>
                    <td>@detail.ProductName</td>
                    <td>@detail.Quantity</td>
                    <td>@detail.UnitPrice.ToString("C")</td>
                    <td>@detail.Subtotal.ToString("C")</td>
                </tr>
            }
        </tbody>
    </table>
    <div class="text-end"><h5>Total: @_order.Total.ToString("C")</h5></div>

    @if (AuthState.Role is "Administrator" or "Delivery")
    {
        <hr />
        <h5>Gestión del pedido</h5>
        <div class="row">
            <div class="col-md-4 mb-3">
                <label class="form-label">Cambiar estado</label>
                <select class="form-select" @bind="_newStatus">
                    @foreach (var status in Enum.GetValues<OrderStatus>())
                    {
                        <option value="@status">@status</option>
                    }
                </select>
                <button class="btn btn-primary btn-sm mt-2" @onclick="UpdateStatusAsync">Actualizar estado</button>
            </div>

            @if (AuthState.Role == "Administrator")
            {
                <div class="col-md-4 mb-3">
                    <label class="form-label">Asignar repartidor</label>
                    <select class="form-select" @bind="_selectedDeliveryId">
                        <option value="0">-- Selecciona --</option>
                        @foreach (var delivery in _availableDeliveries)
                        {
                            <option value="@delivery.Id">@delivery.FirstName @delivery.LastName</option>
                        }
                    </select>
                    <button class="btn btn-primary btn-sm mt-2" @onclick="AssignDeliveryAsync">Asignar</button>
                </div>
            }
        </div>
    }
}

@code {
    [Parameter] public int OrderId { get; set; }

    private OrderDto? _order;
    private List<DeliveryDto> _availableDeliveries = [];
    private OrderStatus _newStatus;
    private int _selectedDeliveryId;
    private string? _message;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthState.IsAuthenticated) return;

        await LoadAsync();

        if (AuthState.Role == "Administrator")
            _availableDeliveries = await UserApi.GetAvailableDeliveries();
    }

    private async Task LoadAsync()
    {
        _order = await OrderApi.GetById(OrderId);
        if (_order is not null)
            _newStatus = _order.Status;
    }

    private async Task UpdateStatusAsync()
    {
        try
        {
            _order = await OrderApi.UpdateStatus(OrderId, new UpdateOrderStatusRequest(_newStatus));
            _message = "Estado actualizado.";
        }
        catch (ApiException ex)
        {
            _message = ex.Message;
        }
    }

    private async Task AssignDeliveryAsync()
    {
        if (_selectedDeliveryId == 0)
        {
            _message = "Selecciona un repartidor.";
            return;
        }

        try
        {
            _order = await OrderApi.AssignDelivery(OrderId, new AssignDeliveryRequest(_selectedDeliveryId));
            _message = "Repartidor asignado.";
            _availableDeliveries = await UserApi.GetAvailableDeliveries();
        }
        catch (ApiException ex)
        {
            _message = ex.Message;
        }
    }
}
