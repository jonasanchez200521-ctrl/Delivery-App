@page "/admin/productos"
@inject CatalogApiService CatalogApi
@inject AuthState AuthState
@inject NavigationManager Navigation

<PageTitle>Productos — Admin</PageTitle>

<AdminNav />

@if (!AuthState.IsAuthenticated || AuthState.Role != "Administrator")
{
    <p>Esta sección es solo para administradores.</p>
}
else
{
    <h3 class="mb-3">Productos</h3>

    @if (!string.IsNullOrEmpty(_message))
    {
        <div class="alert alert-info">@_message</div>
    }

    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Nuevo producto</h5>
            <div class="row g-2">
                <div class="col-md-3"><input class="form-control" placeholder="Nombre" @bind="_newName" /></div>
                <div class="col-md-3"><input class="form-control" placeholder="Descripción" @bind="_newDescription" /></div>
                <div class="col-md-2"><input type="number" step="0.01" class="form-control" placeholder="Precio" @bind="_newPrice" /></div>
                <div class="col-md-1"><input type="number" class="form-control" placeholder="Stock" @bind="_newStock" /></div>
                <div class="col-md-2">
                    <select class="form-select" @bind="_newRestaurantId">
                        <option value="0">Restaurante</option>
                        @foreach (var restaurant in _restaurants)
                        {
                            <option value="@restaurant.Id">@restaurant.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-1">
                    <select class="form-select" @bind="_newCategoryId">
                        <option value="0">Categoría</option>
                        @foreach (var category in _categories)
                        {
                            <option value="@category.Id">@category.Name</option>
                        }
                    </select>
                </div>
            </div>
            <button class="btn btn-primary mt-2" @onclick="CreateAsync">Crear producto</button>
        </div>
    </div>

    @if (_products is null)
    {
        <p>Cargando...</p>
    }
    else
    {
        <table class="table">
            <thead><tr><th>Nombre</th><th>Restaurante</th><th>Categoría</th><th>Precio</th><th>Stock</th><th></th></tr></thead>
            <tbody>
                @foreach (var product in _products)
                {
                    <tr>
                        <td>@product.Name</td>
                        <td>@product.RestaurantName</td>
                        <td>@product.CategoryName</td>
                        <td>@product.Price.ToString("C")</td>
                        <td>@product.Stock</td>
                        <td><button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(product.Id)">Eliminar</button></td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    private List<ProductDto>? _products;
    private List<RestaurantDto> _restaurants = [];
    private List<CategoryDto> _categories = [];

    private string _newName = string.Empty;
    private string _newDescription = string.Empty;
    private decimal _newPrice;
    private int _newStock;
    private int _newRestaurantId;
    private int _newCategoryId;
    private string? _message;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthState.IsAuthenticated || AuthState.Role != "Administrator")
        {
            Navigation.NavigateTo("/login");
            return;
        }

        _restaurants = await CatalogApi.GetRestaurants();
        _categories = await CatalogApi.GetCategories();
        await LoadAsync();
    }

    private async Task LoadAsync() => _products = await CatalogApi.GetProducts();

    private async Task CreateAsync()
    {
        if (string.IsNullOrWhiteSpace(_newName) || _newRestaurantId == 0 || _newCategoryId == 0)
        {
            _message = "Completa nombre, restaurante y categoría.";
            return;
        }

        try
        {
            await CatalogApi.CreateProduct(new CreateProductRequest(
                _newName, _newDescription, _newPrice, _newStock, _newRestaurantId, _newCategoryId));

            _newName = _newDescription = string.Empty;
            _newPrice = 0;
            _newStock = 0;
            await LoadAsync();
        }
        catch (ApiException ex)
        {
            _message = ex.Message;
        }
    }

    private async Task DeleteAsync(int id)
    {
        try
        {
            await CatalogApi.DeleteProduct(id);
            await LoadAsync();
        }
        catch (ApiException ex)
        {
            _message = ex.Message;
        }
    }
}
