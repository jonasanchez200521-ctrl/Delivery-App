@page "/admin/usuarios"
@inject UserApiService UserApi
@inject AuthState AuthState
@inject NavigationManager Navigation

<PageTitle>Usuarios — Admin</PageTitle>

<AdminNav />

@if (!AuthState.IsAuthenticated || AuthState.Role != "Administrator")
{
    <p>Esta sección es solo para administradores.</p>
}
else
{
    <h3 class="mb-3">Usuarios</h3>

    @if (!string.IsNullOrEmpty(_message))
    {
        <div class="alert alert-info">@_message</div>
    }

    <ul class="nav nav-tabs mb-3">
        <li class="nav-item"><button class="nav-link @(_tab == "clients" ? "active" : "")" @onclick='() => _tab = "clients"'>Clientes</button></li>
        <li class="nav-item"><button class="nav-link @(_tab == "couriers" ? "active" : "")" @onclick='() => _tab = "couriers"'>Repartidores</button></li>
        <li class="nav-item"><button class="nav-link @(_tab == "admins" ? "active" : "")" @onclick='() => _tab = "admins"'>Administradores</button></li>
    </ul>

    @if (_tab == "clients")
    {
        <table class="table">
            <thead><tr><th>Nombre</th><th>Correo</th><th>Estado</th><th></th></tr></thead>
            <tbody>
                @foreach (var client in _clients)
                {
                    <tr>
                        <td>@client.FirstName @client.LastName</td>
                        <td>@client.Email</td>
                        <td>@client.Status</td>
                        <td>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => ToggleStatusAsync(client.Id, client.Status)">
                                @(client.Status == UserStatus.Active ? "Bloquear" : "Activar")
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else if (_tab == "couriers")
    {
        <div class="card mb-3">
            <div class="card-body">
                <h6>Nuevo repartidor</h6>
                <div class="row g-2">
                    <div class="col-md-2"><input class="form-control" placeholder="Nombres" @bind="_courierForm.FirstName" /></div>
                    <div class="col-md-2"><input class="form-control" placeholder="Apellidos" @bind="_courierForm.LastName" /></div>
                    <div class="col-md-2"><input class="form-control" placeholder="Correo" @bind="_courierForm.Email" /></div>
                    <div class="col-md-2"><input class="form-control" placeholder="Contraseña" @bind="_courierForm.Password" /></div>
                    <div class="col-md-2"><input class="form-control" placeholder="Placa" @bind="_courierForm.LicencePlate" /></div>
                    <div class="col-md-2">
                        <select class="form-select" @bind="_courierForm.VehicleType">
                            <option value="@VehicleType.Bike">Bicicleta</option>
                            <option value="@VehicleType.Motorcycle">Moto</option>
                            <option value="@VehicleType.Car">Auto</option>
                        </select>
                    </div>
                </div>
                <button class="btn btn-primary mt-2" @onclick="CreateCourierAsync">Crear repartidor</button>
            </div>
        </div>

        <table class="table">
            <thead><tr><th>Nombre</th><th>Correo</th><th>Vehículo</th><th>Disponible</th><th>Estado</th><th></th></tr></thead>
            <tbody>
                @foreach (var courier in _couriers)
                {
                    <tr>
                        <td>@courier.FirstName @courier.LastName</td>
                        <td>@courier.Email</td>
                        <td>@courier.VehicleType (@courier.LicencePlate)</td>
                        <td>@(courier.Availability ? "Sí" : "No")</td>
                        <td>@courier.Status</td>
                        <td>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => ToggleStatusAsync(courier.Id, courier.Status)">
                                @(courier.Status == UserStatus.Active ? "Bloquear" : "Activar")
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="card mb-3">
            <div class="card-body">
                <h6>Nuevo administrador</h6>
                <div class="row g-2">
                    <div class="col-md-2"><input class="form-control" placeholder="Nombres" @bind="_adminForm.FirstName" /></div>
                    <div class="col-md-2"><input class="form-control" placeholder="Apellidos" @bind="_adminForm.LastName" /></div>
                    <div class="col-md-2"><input class="form-control" placeholder="Correo" @bind="_adminForm.Email" /></div>
                    <div class="col-md-2"><input class="form-control" placeholder="Contraseña" @bind="_adminForm.Password" /></div>
                    <div class="col-md-2"><input class="form-control" placeholder="Sucursal" @bind="_adminForm.Branch" /></div>
                    <div class="col-md-2"><input class="form-control" placeholder="Rol" @bind="_adminForm.Rol" /></div>
                </div>
                <button class="btn btn-primary mt-2" @onclick="CreateAdminAsync">Crear administrador</button>
            </div>
        </div>

        <table class="table">
            <thead><tr><th>Nombre</th><th>Correo</th><th>Sucursal</th><th>Rol</th><th>Estado</th></tr></thead>
            <tbody>
                @foreach (var admin in _admins)
                {
                    <tr>
                        <td>@admin.FirstName @admin.LastName</td>
                        <td>@admin.Email</td>
                        <td>@admin.Branch</td>
                        <td>@admin.Rol</td>
                        <td>@admin.Status</td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    private string _tab = "clients";
    private List<ClientDto> _clients = [];
    private List<CourierDto> _couriers = [];
    private List<AdministratorDto> _admins = [];
    private string? _message;

    private readonly CourierFormModel _courierForm = new();
    private readonly AdminFormModel _adminForm = new();

    protected override async Task OnInitializedAsync()
    {
        if (!AuthState.IsAuthenticated || AuthState.Role != "Administrator")
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadAllAsync();
    }

    private async Task LoadAllAsync()
    {
        _clients = await UserApi.GetClients();
        _couriers = await UserApi.GetCouriers();
        _admins = await UserApi.GetAdministrators();
    }

    private async Task ToggleStatusAsync(int userId, UserStatus current)
    {
        var newStatus = current == UserStatus.Active ? UserStatus.Blocked : UserStatus.Active;
        await UserApi.UpdateStatus(userId, new UpdateUserStatusRequest(newStatus));
        await LoadAllAsync();
    }

    private async Task CreateCourierAsync()
    {
        try
        {
            await UserApi.CreateCourier(new CreateCourierRequest(
                _courierForm.FirstName, _courierForm.LastName, "N/D", _courierForm.Email, "N/D",
                Gender.Other, _courierForm.Password, new DateTime(1995, 1, 1),
                _courierForm.VehicleType, _courierForm.LicencePlate));

            await LoadAllAsync();
        }
        catch (ApiException ex)
        {
            _message = ex.Message;
        }
    }

    private async Task CreateAdminAsync()
    {
        try
        {
            await UserApi.CreateAdministrator(new CreateAdministratorRequest(
                _adminForm.FirstName, _adminForm.LastName, "N/D", _adminForm.Email, "N/D",
                Gender.Other, _adminForm.Password, new DateTime(1990, 1, 1),
                _adminForm.Branch, _adminForm.Rol, 0));

            await LoadAllAsync();
        }
        catch (ApiException ex)
        {
            _message = ex.Message;
        }
    }

    private class CourierFormModel
    {
        public string FirstName { get; set; } = string.Empty;
        public string LastName { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public string LicencePlate { get; set; } = string.Empty;
        public VehicleType VehicleType { get; set; } = VehicleType.Motorcycle;
    }

    private class AdminFormModel
    {
        public string FirstName { get; set; } = string.Empty;
        public string LastName { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public string Branch { get; set; } = string.Empty;
        public string Rol { get; set; } = string.Empty;
    }
}
